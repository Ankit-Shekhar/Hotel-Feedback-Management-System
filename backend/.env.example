NODE_ENV=production
PORT=8000
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-url>

# Comma-separated origins allowed to access backend with credentials.
# Example: https://your-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=https://your-frontend.vercel.app

ADMIN_TOKEN_SECRET=replace_with_a_long_random_secret
ADMIN_TOKEN_EXPIRY=7d

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional Redis config (backend still works without Redis)
REDIS_URL=
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=

# Keep false in production unless intentionally seeding once
SEED_DEFAULT_ADMIN=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=
